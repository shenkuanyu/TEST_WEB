# =============================================================
#  正式環境環境變數範本
#  部署時請複製成 .env.production 並填入實際值
# =============================================================

# JWT 簽章金鑰（請務必改為至少 32 字元的隨機亂碼）
JWT_SECRET=請改為一段夠長的隨機字串_請勿使用預設值

# 後台預設管理員（首次執行 init-db 時生效）
ADMIN_EMAIL=poshtech
ADMIN_PASSWORD=請改為強密碼

# 資料庫位置（容器內的持久化路徑）
DATABASE_PATH=/app/data/app.db

# Node.js 執行環境
NODE_ENV=production
PORT=3000
