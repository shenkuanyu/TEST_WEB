import Link from 'next/link';
import HeroCarousel from '@/components/HeroCarousel';
import ProductCard from '@/components/ProductCard';
import NewsCard from '@/components/NewsCard';
import { getDB } from '@/lib/db';

export const dynamic = 'force-dynamic';

export default function Home() {
  const db = getDB();
  const banners = db.prepare('SELECT * FROM banners WHERE active=1 ORDER BY sort_order').all();
  const products = db.prepare('SELECT * FROM products WHERE published=1 ORDER BY sort_order, id DESC LIMIT 4').all();
  const featuredCats = db.prepare(`
    SELECT c.* FROM categories c ORDER BY c.sort_order LIMIT 3
  `).all();
  const news = db.prepare('SELECT * FROM news WHERE published=1 ORDER BY id DESC LIMIT 3').all();

  // 取站台設定
  const settings = {};
  db.prepare('SELECT key, value FROM site_settings').all().forEach(r => (settings[r.key] = r.value));

  // 分類橫幅圖檔對照
  const catBanner = {
    '斜楔': '/uploads/cat-xieqie.jpg',
    '聯軸器': '/uploads/cat-coupling.jpg',
    '軸承座': '/uploads/cat-bearing.jpg',
  };

  return (
    <>
      <HeroCarousel banners={banners} />

      {/* 精選產品（原站「零組件標準化的專家」區塊） */}
      <section className="container py-20">
        <div className="text-center mb-12">
          <h2 className="text-3xl md:text-4xl font-light text-gray-900">
            {settings.site_slogan || '零組件標準化的專家'}
          </h2>
          <p className="mt-4 text-gray-500 leading-relaxed whitespace-pre-line max-w-2xl mx-auto">
            {settings.site_subtitle}
          </p>
        </div>
        <div className="grid grid-cols-2 lg:grid-cols-4 gap-6">
          {products.map(p => <ProductCard key={p.id} product={p} />)}
        </div>
        <div className="text-center mt-10">
          <Link href="/products" className="btn-outline">查看全部產品</Link>
        </div>
      </section>

      {/* 聯絡資訊區塊（對應原站 Contact Us 區塊） */}
      <section className="bg-gray-50 py-20">
        <div className="container grid md:grid-cols-3 gap-6 items-stretch">
          <div className="hidden md:block">
            <img src="/uploads/contact-1.jpg" alt="" className="w-full h-full object-cover rounded-lg" />
          </div>
          <div className="bg-white p-10 rounded-lg border-t-4 border-brand">
            <p className="section-sub mb-3 !text-brand">CONTACT US</p>
            <h3 className="text-2xl font-light mb-6">聯絡我們</h3>
            <div className="text-sm text-gray-600 space-y-2 leading-relaxed">
              <p>{settings.contact_address}</p>
              <p>TEL：{settings.contact_phone}</p>
              <p>FAX：{settings.contact_fax}</p>
              <p>E-mail：<a href={`mailto:${settings.contact_email}`} className="text-brand hover:underline">{settings.contact_email}</a></p>
            </div>
            <Link href="/contact" className="btn-primary mt-8">立即詢價</Link>
          </div>
          <div className="hidden md:block">
            <img src="/uploads/contact-2.jpg" alt="" className="w-full h-full object-cover rounded-lg" />
          </div>
        </div>
      </section>

      {/* 關於我們（對應原站「關於久洋」區塊） */}
      <section className="container py-20">
        <div className="grid md:grid-cols-2 gap-12 items-center">
          <div>
            <p className="section-sub mb-3 !text-brand">SINCE 1994</p>
            <h3 className="text-3xl font-light mb-4">關於久洋</h3>
            <p className="text-gray-600 leading-loose mb-6">
              久洋機械股份有限公司創立於 1994 年 7 月，以研究設計為本，
              協助台灣中小企業解決研發人才短缺的難題，讓零組件標準化成為我們的核心價值。
            </p>
            <Link href="/about" className="btn-outline">More Info</Link>
          </div>
          <div>
            <img src="/uploads/about.jpg" alt="關於久洋" className="w-full rounded-lg shadow-sm" />
          </div>
        </div>
      </section>

      {/* 產品類別展示（對應原站底部三大類別 banner） */}
      <section className="bg-gray-50 py-20">
        <div className="container">
          <div className="text-center mb-10">
            <p className="section-sub mb-3">CATEGORIES</p>
            <h2 className="section-title">主要產品類別</h2>
          </div>
          <div className="grid md:grid-cols-3 gap-6">
            {featuredCats.map(c => (
              <Link
                key={c.id}
                href={`/products?cat=${c.id}`}
                className="group relative block overflow-hidden rounded-lg aspect-[16/7]"
              >
                <img
                  src={catBanner[c.name] || '/uploads/placeholder.svg'}
                  alt={c.name}
                  className="w-full h-full object-cover group-hover:scale-110 transition duration-500"
                />
                <div className="absolute inset-0 bg-black/30 group-hover:bg-black/50 transition flex items-center justify-center">
                  <h3 className="text-white text-2xl font-semibold tracking-widest">{c.name}</h3>
                </div>
              </Link>
            ))}
          </div>
        </div>
      </section>

      {/* 最新消息 */}
      {news.length > 0 && (
        <section className="container py-20">
          <div className="flex items-end justify-between mb-10">
            <div>
              <p className="section-sub mb-3">NEWS</p>
              <h2 className="section-title">最新消息</h2>
            </div>
            <Link href="/news" className="text-sm text-gray-600 hover:text-brand">查看全部 →</Link>
          </div>
          <div className="grid grid-cols-1 md:grid-cols-3 gap-6">
            {news.map(n => <NewsCard key={n.id} item={n} />)}
          </div>
        </section>
      )}

      {/* CTA */}
      <section className="bg-brand text-white py-16">
        <div className="container text-center">
          <h2 className="text-2xl md:text-3xl font-light mb-3">有產品需求嗎？</h2>
          <p className="text-white/80 mb-8">歡迎來電或寄信聯絡我們，我們將盡快回覆您。</p>
          <div className="flex flex-wrap justify-center gap-4">
            <a href={`tel:${settings.contact_phone}`} className="inline-flex items-center px-6 py-3 bg-white text-brand rounded-md hover:bg-gray-100 transition font-medium">
              TEL：{settings.contact_phone}
            </a>
            <Link href="/contact" className="inline-flex items-center px-6 py-3 border border-white text-white rounded-md hover:bg-white hover:text-brand transition">
              線上詢價
            </Link>
          </div>
        </div>
      </section>
    </>
  );
}
