# =========================================================
#  Production 環境變數（請 cp 為 .env.production 後修改）
# =========================================================

# JWT 密鑰：兩站共用，請務必改為 32+ 字元的亂碼
# 產生方式：openssl rand -base64 48
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_STRING_AT_LEAST_32_CHARS

# 預設管理員（首次 init-db 時寫入）
ADMIN_EMAIL=poshtech
ADMIN_PASSWORD=請改成強密碼

# Next.js
NODE_ENV=production
NEXT_TELEMETRY_DISABLED=1
